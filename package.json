{
  "name": "next-sns",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron": "electron .",
    "dev:desktop": "concurrently \"npm run dev\" \"npm run electron\"",
    "dist": "next build && electron-builder"
  },
  "build": {
    "appId": "com.next-sns.app",
    "productName": "Next SNS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!.git/**/*",
      "!scratch.mjs",
      "!implementation_plan.md",
      "!task.md"
    ],
    "asar": false,
    "win": {
      "target": "portable"
    }
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "dist": "^0.1.2",
    "easymde": "^2.20.0",
    "electron-is-dev": "^3.0.1",
    "electron-next": "^3.1.5",
    "formidable": "^3.5.4",
    "fs": "^0.0.1-security",
    "github-markdown-css": "^5.9.0",
    "gray-matter": "^4.0.3",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "react-simplemde-editor": "^5.2.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/formidable": "^3.5.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
